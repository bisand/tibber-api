{
  "transform": {
    "^.+\\.(t|j)sx?$": ["ts-jest", { "tsconfig": { "types": ["jest", "node"], "isolatedModules": true, "rootDir": "." } }]
  },
  "testRegex": "(/tests/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
  "moduleFileExtensions": [
    "ts",
    "tsx",
    "js",
    "jsx",
    "json",
    "node"
  ],
  "testSequencer": "./test-sequencer.js",
  "detectOpenHandles": true
}